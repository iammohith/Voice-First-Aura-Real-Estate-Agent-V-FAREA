# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# WHATSAPP_ACCESS_TOKEN: Required for official Meta WhatsApp Cloud Business API calls.
# Obtain a permanent System User Token from your Meta Developer Dashboard.
WHATSAPP_ACCESS_TOKEN="MY_WHATSAPP_ACCESS_TOKEN"

# WHATSAPP_PHONE_NUMBER_ID: The unique ID associated with your registered WhatsApp Business Sender.
WHATSAPP_PHONE_NUMBER_ID="MY_WHATSAPP_PHONE_NUMBER_ID"

# WHATSAPP_TEMPLATE_NAME: Optional custom message template name registered on Meta.
# Defaults to "signature_estates_presales_brochure" if left empty.
WHATSAPP_TEMPLATE_NAME="signature_estates_presales_brochure"
